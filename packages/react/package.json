{
  "name": "@r6ops/operators-react",
  "version": "1.0.0",
  "description": "React component wrapper for @r6ops/operators — render R6S operator icons as React elements",
  "keywords": [
    "rainbow six siege",
    "r6",
    "R6S",
    "operator",
    "icon",
    "svg",
    "react",
    "component"
  ],
  "homepage": "https://zerobertoo.github.io/r6operators",
  "bugs": "https://github.com/zerobertoo/operators/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/zerobertoo/operators.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "author": "Jose Roberto <euzerobertoo@gmail.com> (https://github.com/zerobertoo)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@r6ops/operators": ">=2.12.0",
    "react": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@r6ops/operators": "file:../..",
    "react": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
